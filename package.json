{
  "name": "manhwa-pipeline",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-side manhwa recap script generator. PDF → cleaned images + Gemini-generated narration script.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build:win": "npm run build && electron-packager . \"Manhwa Recap\" --overwrite --platform=win32 --arch=x64 --out=release --prune=true --ignore=\"^/src\" --ignore=\"^/public\" --ignore=\"^/extension\" --ignore=\"^/release\" --ignore=\"^/.git\" --ignore=\"^/.vercel\" --ignore=\"^/.vite\" --ignore=\"^/tsconfig\" --ignore=\"^/vite.config\" --ignore=\"^/postcss.config\" --ignore=\"^/tailwind.config\"",
    "electron:build:mac": "npm run build && electron-packager . \"Manhwa Recap\" --overwrite --platform=darwin --arch=x64,arm64 --out=release --prune=true --ignore=\"^/src\" --ignore=\"^/public\" --ignore=\"^/extension\" --ignore=\"^/release\" --ignore=\"^/.git\" --ignore=\"^/.vercel\" --ignore=\"^/.vite\" --ignore=\"^/tsconfig\" --ignore=\"^/vite.config\" --ignore=\"^/postcss.config\" --ignore=\"^/tailwind.config\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
